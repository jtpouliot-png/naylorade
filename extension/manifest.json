{
  "manifest_version": 3,
  "name": "Naylorade Roster Sync",
  "version": "1.0",
  "description": "One-click sync your ESPN Fantasy Baseball roster to Naylorade",
  "permissions": ["cookies", "storage", "tabs", "scripting"],
  "host_permissions": [
    "*://*.espn.com/*",
    "*://*/*",
    "http://*/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Naylorade Roster Sync"
  },
  "content_scripts": [
    {
      "matches": ["*://fantasy.espn.com/*", "*://www.espn.com/fantasy/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["interceptor.js"],
      "matches": ["*://fantasy.espn.com/*", "*://www.espn.com/fantasy/*"]
    }
  ]
}
